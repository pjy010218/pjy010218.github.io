@inproceedings{25CISC'S,
  author    = { Park, Junyeong and Kim, Jonghyun },
  booktitle = { 2025 Summer Conference on Information Security and Cryptography (CISC) },
  title     = { Automating Honeypots through Digital Twins and MITRE ATT&CK TTP Mapping },
  year      = {2025},
  pages     = {},
  abstract  = { This study proposes and experimentally validates a Digital Twin Honeypot (DT Honeypot), an active cyber deception system designed to overcome the limitations of conventional honeypots by leveraging Digital Twin (DT) technology. To achieve this, the proposed system integrates the real-time synchronization capability of digital twins—which continuously replicate changes occurring in the original system to its virtual counterpart—with honeypot technology. To minimize the risk of sensitive data exposure resulting from this synchronization process, a data fictionalization module was designed and implemented. Furthermore, the system incorporates a real-time attack monitoring module that maps attacker activities to the Tactics, Techniques, and Procedures (TTPs) defined in the MITRE ATT&CK framework. Based on the identified attack patterns, the system dynamically exposes an appropriate layer of deceptive assets, thereby minimizing the scope of fake resources revealed to the attacker while maintaining the effectiveness of the deception strategy. Experimental results demonstrate that the DT Honeypot provides greater stability and flexibility than traditional static honeypots. Unlike conventional honeypots, the proposed system can adapt autonomously to changes in the original environment, significantly reducing maintenance costs associated with deception systems. Moreover, by addressing the challenges introduced by the use of digital twin technology, the DT Honeypot is shown to function effectively as an active and adaptive security mechanism.
               },
  keywords  = {Deception;Digital Twin;Honeypot;IaC;MITRE ATT&CK},
  doi       = {},
  url       = {},
  publisher = {Korea Institute of Information Security & Cryptology},
  address   = {Seoul, Republic of Korea},
  month     = June
}